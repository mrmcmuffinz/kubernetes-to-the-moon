# Version pins for the single-systemd cluster build.
# All four cluster-setup guides (single-systemd, single-kubeadm, two-systemd, two-kubeadm)
# target the same component versions so labs are consistent.
#
# How to bump when the CKA exam target changes (e.g., 1.35 -> 1.36):
#   1. Update k8s_version and cri_version (cri-tools tracks Kubernetes minor version).
#   2. Check containerd releases: https://github.com/containerd/containerd/releases
#   3. Check runc releases: https://github.com/opencontainers/runc/releases
#   4. Check etcd releases: https://github.com/etcd-io/etcd/releases
#   5. Check CNI plugins releases: https://github.com/containernetworking/plugins/releases
#   6. Update this file and the version tables in each guide's README.md and 00-overview.md.
#   7. The kubernetes cert in 02-bootstrapping-security.md has a 10-year expiry baked in at
#      generation time -- no action needed just for a version bump (only re-generate certs if
#      the SAN list or cluster CA changes).
#   Verified against upstream releases: 2026-04-27
export PAGER=cat
export arch=amd64
export cni_plugins_version=1.7.1
export cni_spec_version=1.0.0
export containerd_version=2.1.3
export cri_version=1.35.0
export etcd_version=3.6.9
export k8s_version=1.35.3
export pod_cidr=10.244.0.0/16
export runc_version=1.3.0
export vmaddr=10.0.2.15
export vmname=controlplane-1
